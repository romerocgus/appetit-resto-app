datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// --- CORE: Usuarios y Bares ---

model Bar {
  id             String      @id @default(cuid())
  name           String
  slug           String      @unique
  email          String      @unique
  address        String?
  phone          String?
  whatsappNumber String      
  logoUrl        String?
  image          String?
  description    String?
  themeConfig    Json?
  
  staff          BarMember[]
  categories     Category[]
  products       Product[]
  menus          Menu[]
  orders         Order[]     // <-- RELACIÓN AÑADIDA

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  password     String
  phone        String?

  memberships  BarMember[]

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model BarMember {
  id           String       @id @default(cuid())
  role         String       @default("viewer")

  userId       String
  barId        String
  user         User         @relation(fields: [userId], references: [id])
  bar          Bar          @relation(fields: [barId], references: [id])

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  @@unique([userId, barId]) // Evita que un usuario esté duplicado en el mismo bar
}

// --- ESTRUCTURA DE CARTA ---

model Category {
  id           String       @id @default(cuid())
  name         String
  image        String?
  description  String?
  order        Int          @default(0) // Para ordenar las secciones en la carta

  barId        String
  bar          Bar          @relation(fields: [barId], references: [id])
  products     Product[]
  menus        CategoriesInMenus[] // <-- RELACIÓN AÑADIDA
  // Permite que una categoría esté presente en varios menús

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Product {
  id            String      @id @default(cuid())
  name          String
  image         String
  description   String
  allergens     String[]
  price         Float

  isShareable   Boolean     @default(false)
  isAvailable   Boolean     @default(true)
  canBeInMenu   Boolean     @default(true)
  
  categoryId    String
  category      Category    @relation(fields: [categoryId], references: [id])
  barId         String
  bar           Bar         @relation(fields: [barId], references: [id])
  menus         ProductsInMenus[]
  orderItems    OrderItem[] // Relación con pedidos

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Menu {
  id            String      @id @default(cuid())
  name          String
  image         String
  description   String
  price         Float       // Precio fijo del menú

  isAvailable   Boolean     @default(true)

  barId         String
  bar           Bar         @relation(fields: [barId], references: [id])
  products      ProductsInMenus[]
  categories    CategoriesInMenus[] // <-- Define qué categorías componen este menú
  orderItems    OrderItem[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

// --- TABLAS INTERMEDIAS DE LÓGICA ---

model CategoriesInMenus {
  menuId        String
  categoryId    String
  menu          Menu        @relation(fields: [menuId], references: [id])
  category      Category    @relation(fields: [categoryId], references: [id])
  @@id([menuId, categoryId])
}

model ProductsInMenus {
  productId     String
  menuId        String
  product       Product     @relation(fields: [productId], references: [id])
  menu          Menu        @relation(fields: [menuId], references: [id])
  @@id([productId, menuId])
}

// --- SISTEMA DE PEDIDOS ---

model Order {
  id            String      @id @default(cuid())
  customerName  String?
  tableNumber   String?     // Por si piden desde la mesa
  totalPrice    Float
  status        String      @default("PENDING") // PENDING, DELIVERED, CANCELLED
  
  barId         String
  bar           Bar         @relation(fields: [barId], references: [id])
  items         OrderItem[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  quantity  Int      @default(1)
  price     Float    // Precio en el momento de la compra (histórico)
  
  order     Order    @relation(fields: [orderId], references: [id])
  // Un ítem de pedido puede ser un Producto O un Menú
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  menuId    String?
  menu      Menu?    @relation(fields: [menuId], references: [id])
}